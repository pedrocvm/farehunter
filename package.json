{
  "name": "farehunter",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "pnpm --filter @farehunter/web dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "worker": "pnpm --filter @farehunter/worker dev",
    "db:generate": "pnpm --filter @farehunter/db prisma generate",
    "db:migrate": "pnpm --filter @farehunter/db prisma migrate dev",
    "db:studio": "pnpm --filter @farehunter/db prisma studio",
    "db:seed": "pnpm --filter @farehunter/db run seed",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,css,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "typescript-eslint": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "sharp"
    ]
  }
}
